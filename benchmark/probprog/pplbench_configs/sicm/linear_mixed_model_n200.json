{
  "model": {
    "class": "linear_mixed_model.LinearMixedModel",
    "args": {
      "n": 200,
      "k": 3,
      "q": 20
    },
    "seed": 12345
  },
  "iterations": 1500,
  "num_warmup": 500,
  "trials": 4,
  "ppls": [
    {
      "name": "numpyro",
      "inference": {
        "class": "inference.MCMC",
        "infer_args": {
          "step_size": 0.1,
          "max_tree_depth": 10,
          "adapt_step_size": true,
          "adapt_mass_matrix": true
        }
      },
      "legend": {
        "name": "NumPyro",
        "color": "blue"
      },
      "trials": 4
    },
    {
      "name": "impulse",
      "inference": {
        "class": "inference.MCMC",
        "infer_args": {
          "step_size": 0.1,
          "max_tree_depth": 10,
          "adapt_step_size": true,
          "adapt_mass_matrix": true
        }
      },
      "legend": {
        "name": "Impulse",
        "color": "red"
      },
      "trials": 4
    },
    {
      "name": "impulse",
      "inference": {
        "class": "inference.MCMC",
        "infer_args": {
          "step_size": 0.1,
          "max_tree_depth": 10,
          "adapt_step_size": true,
          "adapt_mass_matrix": true,
          "disable_opt": true
        }
      },
      "legend": {
        "name": "Impulse (no opt)",
        "color": "orange"
      },
      "trials": 4,
      "optional": true
    },
    {
      "name": "pymc",
      "inference": {
        "class": "inference.MCMC",
        "infer_args": {
          "step_size": 0.1,
          "max_tree_depth": 10,
          "adapt_step_size": true,
          "adapt_mass_matrix": true
        }
      },
      "legend": {
        "name": "PyMC",
        "color": "darkgreen"
      },
      "trials": 2,
      "optional": true
    }
  ],
  "save_samples": true,
  "figures": {
    "generate_pll": true,
    "suffix": "png"
  }
}
